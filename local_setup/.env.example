# DHIS2 Configuration
# Use a local docker instance or DHIS2 Play sandbox for development
DHIS2_BASE_URL="https://play.dhis2.org/40.0.1" 
DHIS2_USERNAME="admin" 
DHIS2_PAT="d2pat_your_token_here_xxxx" # Your generated PAT token

# Africa's Talking (AT) Configuration
AT_USERNAME="sandbox"                  # Sandbox environment default username
AT_API_KEY="your_at_api_key_here"      # AT Sandbox API Key
AT_USSD_SHORTCODE="*384*MAMA#"         # Your registered AT USSD shortcode

# Local Node.js Express server
PORT=3000
